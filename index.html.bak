<!DOCTYPE html>
<html lang="mg">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Media SDA Ambolokandrina</title>
<meta name="theme-color" content="#0A0F1E">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{
  font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display','Helvetica Neue',sans-serif;
  background:#0A0F1E;color:rgba(255,255,255,0.97);
  min-height:100vh;overflow:hidden;
  -webkit-font-smoothing:antialiased;
}
/* ══ SPLASH ══ */
.splash{
  position:fixed;inset:0;z-index:1000;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:linear-gradient(145deg,#0A0F1E 0%,#0D2140 50%,#0A1628 100%);
  transition:opacity .7s ease,transform .7s ease;
}
.splash.exit{opacity:0;transform:scale(1.06);filter:blur(4px);pointer-events:none}
.splash-logo{
  width:110px;height:110px;
  background:linear-gradient(135deg,#0A84FF,#5AC8FA);
  border-radius:28px;display:flex;align-items:center;justify-content:center;
  font-size:50px;
  box-shadow:0 0 60px rgba(10,132,255,.5),0 0 120px rgba(10,132,255,.2);
  animation:logoPulse 2s ease-in-out infinite;margin-bottom:24px;
}
@keyframes logoPulse{
  0%,100%{transform:scale(1);box-shadow:0 0 60px rgba(10,132,255,.5),0 0 120px rgba(10,132,255,.2)}
  50%{transform:scale(1.04);box-shadow:0 0 80px rgba(10,132,255,.7),0 0 160px rgba(10,132,255,.3)}
}
.splash-typing{display:flex;flex-direction:column;align-items:center;gap:4px;min-height:100px;margin-bottom:36px}
.splash-line{font-size:26px;font-weight:500;letter-spacing:1px;color:rgba(255,255,255,.7);height:34px;white-space:nowrap}
.splash-line.highlight{font-size:36px;font-weight:700;letter-spacing:-.5px;background:linear-gradient(135deg,#fff 0%,rgba(90,200,250,.9) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.splash-cursor{display:inline-block;font-weight:300;color:#5AC8FA;-webkit-text-fill-color:#5AC8FA;width:2px;animation:cursorBlink .6s step-end infinite}
@keyframes cursorBlink{0%,100%{opacity:1}50%{opacity:0}}
.splash-loader{width:200px;height:3px;background:rgba(255,255,255,.1);border-radius:2px;overflow:hidden}
.splash-loader-bar{height:100%;background:linear-gradient(90deg,#0A84FF,#5AC8FA);border-radius:2px;width:0%}
.splash-sig{position:absolute;bottom:40px;font-size:13px;color:rgba(255,255,255,.4);letter-spacing:2px;text-transform:uppercase}

/* ══ MAIN HOME ══ */
.main-home{
  position:relative;z-index:1;height:100vh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:24px;opacity:0;transition:opacity .6s ease;
}
.main-home.visible{opacity:1}
.main-home-title{text-align:center;margin-bottom:28px}
.main-home-title h1{
  font-size:38px;font-weight:800;letter-spacing:-1px;margin-bottom:8px;
  background:linear-gradient(135deg,#fff 0%,rgba(90,200,250,.9) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.main-home-title p{font-size:14px;color:rgba(255,255,255,.5);letter-spacing:1px;text-transform:uppercase}
.home-cards{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;max-width:720px}
.home-card{
  flex:1;min-width:200px;max-width:280px;
  padding:28px 22px;border-radius:20px;cursor:pointer;overflow:hidden;
  background:rgba(255,255,255,.06);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid rgba(255,255,255,.15);
  box-shadow:0 8px 32px rgba(0,0,0,.25);
  transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s;
  text-align:center;position:relative;will-change:transform;
  animation:cardIn .5s cubic-bezier(.22,1,.36,1) both;
}
.home-card:nth-child(1){animation-delay:.1s}
.home-card:nth-child(2){animation-delay:.18s}
.home-card:nth-child(3){animation-delay:.26s}
@keyframes cardIn{from{opacity:0;transform:translateY(30px) scale(.95)}to{opacity:1;transform:translateY(0) scale(1)}}
.home-card:hover{transform:translateY(-5px) scale(1.02);box-shadow:0 16px 48px rgba(0,0,0,.4)}
.home-card:active{transform:scale(.97)}
.home-card::before{content:'';position:absolute;inset:0;background:var(--accent);opacity:.08;border-radius:inherit}
.home-card.bible{--accent:linear-gradient(135deg,#0A84FF,#5AC8FA)}
.home-card.hymns{--accent:linear-gradient(135deg,#FF9F0A,#FF6B6B)}
.home-card.sabata{--accent:linear-gradient(135deg,#34C759,#5AC8FA)}
.hc-icon{font-size:44px;margin-bottom:12px}
.hc-title{font-size:20px;font-weight:700;margin-bottom:4px}
.hc-sub{font-size:13px;color:rgba(255,255,255,.5);margin-bottom:12px}
.hc-badge{
  display:inline-block;padding:4px 12px;border-radius:10px;font-size:12px;font-weight:600;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.12);
}
.home-sig{position:absolute;bottom:24px;font-size:11px;color:rgba(255,255,255,.3);letter-spacing:2px;text-transform:uppercase}

/* ══ BG ══ */
.bg-canvas{
  position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 80% 60% at 20% 10%,rgba(10,132,255,.35) 0%,transparent 60%),
    radial-gradient(ellipse 60% 80% at 80% 80%,rgba(90,200,250,.2) 0%,transparent 60%),
    radial-gradient(ellipse 50% 50% at 60% 30%,rgba(52,199,89,.1) 0%,transparent 50%),
    linear-gradient(160deg,#0A0F1E 0%,#0D1B2A 40%,#0A1628 100%);
  animation:bgPulse 12s ease-in-out infinite alternate;
}
@keyframes bgPulse{0%{filter:hue-rotate(0deg) brightness(1)}50%{filter:hue-rotate(10deg) brightness(1.05)}100%{filter:hue-rotate(-5deg) brightness(.98)}}

/* ══ SLIDESHOW ══ */
.slideshow{
  position:fixed;inset:0;z-index:2000;
  opacity:0;pointer-events:none;
  transition:opacity .5s ease;
}
.slideshow.open{opacity:1;pointer-events:all}

.slide{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background-size:cover;background-position:center;background-repeat:no-repeat;
  opacity:0;transition:opacity .6s cubic-bezier(.22,1,.36,1),transform .6s cubic-bezier(.22,1,.36,1);
  transform:scale(1.04);padding:40px 24px;
}
.slide.active{opacity:1;transform:scale(1)}
.slide::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(180deg,rgba(0,0,0,.35) 0%,rgba(0,0,0,.55) 50%,rgba(0,0,0,.8) 100%);
}
.slide-content{
  position:relative;z-index:2;text-align:center;
  width:100%;max-width:800px;
  animation:slideContentIn .7s cubic-bezier(.22,1,.36,1) both;
}
@keyframes slideContentIn{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.slide h1{
  font-size:clamp(32px,6vw,64px);font-weight:800;letter-spacing:-1px;
  line-height:1.2;margin-bottom:12px;
  text-shadow:0 2px 20px rgba(0,0,0,.5);
}
.slide .sub{
  font-size:clamp(16px,2.5vw,26px);font-weight:500;letter-spacing:2px;
  text-transform:uppercase;color:rgba(255,255,255,.7);
  text-shadow:0 2px 12px rgba(0,0,0,.4);
}
.slide .number{
  position:absolute;top:20px;right:24px;z-index:5;
  font-size:15px;font-weight:700;letter-spacing:2px;
  color:rgba(255,255,255,.5);text-shadow:0 2px 8px rgba(0,0,0,.4);
}

/* Timer */
.timer{
  font-size:clamp(48px,10vw,100px);font-weight:800;letter-spacing:4px;
  font-variant-numeric:tabular-nums;
  text-shadow:0 4px 30px rgba(0,0,0,.5);margin:8px 0 4px;
  background:linear-gradient(135deg,rgba(255,255,255,.95),rgba(90,200,250,.9));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  transition:transform .15s ease;
}
.timer.pop{transform:scale(1.06)}
.timer-bar-wrap{
  width:min(300px,70vw);height:6px;
  background:rgba(255,255,255,.15);border-radius:3px;overflow:hidden;
  margin:12px auto 0;
}
.timer-bar{
  height:100%;background:linear-gradient(90deg,#0A84FF,#5AC8FA);
  border-radius:3px;width:100%;transition:width 1s linear;
}



/* Controls */
.slide-controls{
  position:absolute;bottom:0;left:0;right:0;z-index:10;
  padding:20px 24px 32px;
  background:linear-gradient(0deg,rgba(0,0,0,.6) 0%,transparent 100%);
  transition:opacity .35s ease;
}
.ctrl-row{display:flex;align-items:center;justify-content:space-between;gap:16px}
.ctrl-btn{
  width:48px;height:48px;border-radius:50%;border:none;cursor:pointer;
  background:rgba(255,255,255,.12);backdrop-filter:blur(12px);
  color:#fff;font-size:22px;display:flex;align-items:center;justify-content:center;
  transition:all .2s;flex-shrink:0;
}
.ctrl-btn:hover{background:rgba(255,255,255,.2);transform:scale(1.06)}
.ctrl-btn:active{transform:scale(.92)}
.ctrl-btn.exit{background:rgba(255,59,48,.25)}
.ctrl-btn.exit:hover{background:rgba(255,59,48,.4)}
.ctrl-progress{
  flex:1;height:4px;background:rgba(255,255,255,.12);border-radius:2px;overflow:hidden;cursor:pointer;
}
.ctrl-progress-fill{height:100%;background:linear-gradient(90deg,#0A84FF,#5AC8FA);border-radius:2px;transition:width .3s}
.ctrl-label{font-size:13px;font-weight:600;color:rgba(255,255,255,.5);letter-spacing:1px;white-space:nowrap;min-width:50px;text-align:center}
.play-btn{
  width:56px;height:56px;border-radius:50%;border:none;cursor:pointer;
  background:linear-gradient(135deg,#0A84FF,#5AC8FA);
  color:#fff;font-size:26px;display:flex;align-items:center;justify-content:center;
  transition:all .2s;flex-shrink:0;box-shadow:0 4px 20px rgba(10,132,255,.4);
}
.play-btn:hover{transform:scale(1.06);box-shadow:0 6px 28px rgba(10,132,255,.5)}
.play-btn:active{transform:scale(.92)}

/* Close btn */
.slide-close{
  position:absolute;top:16px;left:16px;z-index:20;
  width:44px;height:44px;border-radius:50%;border:none;cursor:pointer;
  background:rgba(0,0,0,.4);backdrop-filter:blur(12px);
  color:rgba(255,255,255,.7);font-size:20px;display:flex;align-items:center;justify-content:center;
  transition:opacity .35s ease,background .2s;
}
.slide-close:hover{background:rgba(255,59,48,.5);color:#fff}

/* Responsive */
@media(max-width:500px){
  .splash-line{font-size:18px}
  .splash-line.highlight{font-size:26px}
  .main-home-title h1{font-size:28px}
  .home-card{min-width:160px;padding:20px 16px}
  .hc-icon{font-size:32px}

  .ctrl-btn{width:40px;height:40px;font-size:18px}
  .play-btn{width:48px;height:48px;font-size:22px}
}
</style>
</head>
<body>
<div class="bg-canvas" aria-hidden="true"></div>
<div id="root"></div>

<script>
(function(){
  const slides = [
    { id:1, title:"FANAHIN'NY FAMINANIANA", sub:"Fanompoam-pivavahana Sabata" },
    { id:2, title:"DIA-BE", sub:"Famakiana soratra masina" },
    { id:3, title:"DIMY MINITRA", sub:"----", timer:300},
    { id:4, title:"SEKOLY SABATA", sub:"Famerenan-desona", timer:1800 },
    { id:5, title:"FOLO MINITRA", sub:"Asa fitoriana", timer:600 },
    { id:6, title:"TATITRA SEKOLY SABATA", sub:"Tatitra" },
    { id:7, title:"FILAZANA", sub:"Filazana" },
    { id:8, title:"SALAMO", sub:"Vakiteny Salamo" },
    { id:9, title:"FIARAHABANA", sub:"Fiarahabana" },
    { id:10, title:"ANDININY FOTOTRA", sub:"Andininy Fototra" },
    { id:11, title:"VAVAKA MANDOHALIKA", sub:"Vavaka" },
    { id:12, title:"FAMPIRISIHANA FANATITRA sy AMPAHAFOLONY", sub:"Fanatitra sy Ampahafolony" },
    { id:13, title:"TORITENY HOAN'NY ANKIZY", sub:"Toriteny" },
    { id:14, title:"CHORALE FE.ZA.SI.A", sub:"Chorale" },
    { id:15, title:"TORITENY ANTOANDRO", sub:"Toriteny Antoandro" },
    { id:16, title:"MIRARY TOHINY SABATA MAHAFINARITRA", sub:"Amin'ny 14h30 indray" }
  ];

  const root=document.getElementById('root');
  let currentSlide=0, timerInterval=null, timerRemaining=0, isPlaying=false;
  let slideShowEl=null, timerDisplay=null, timerBar=null, progressFill=null, labelEl=null, playBtn=null;

  /* ── SPLASH ── */
  const texts=[
    {text:"Hello",cls:"splash-line"},
    {text:"Arahabaina fa nahatratra ny Sabata Masina",cls:"splash-line"},
    {text:"Mifantoha, ka hitahy anao ny Tompo!",cls:"splash-line highlight"}
  ];
  const splash=document.createElement('div');splash.className='splash';
  splash.innerHTML=`
    <div class="splash-logo">&#x1F54A;</div>
    <div class="splash-typing" id="splashType"></div>
    <div class="splash-loader"><div class="splash-loader-bar" id="splashBar"></div></div>
    <div class="splash-sig">Media SDA Ambolokandrina</div>
  `;
  root.appendChild(splash);
  const tc=document.getElementById('splashType'),bar=document.getElementById('splashBar');
  let ti=0,ci=0,done=false;
  function typeNext(){
    if(ti>=texts.length){if(!done){done=true;bar.style.width='100%';setTimeout(()=>{splash.classList.add('exit');setTimeout(()=>{splash.style.display='none';showHome()},700)},400)}return}
    const c=texts[ti];
    if(ci===0){const l=document.createElement('div');l.className=c.cls;l.id='activeLine';tc.appendChild(l)}
    const l=document.getElementById('activeLine');
    if(ci<c.text.length){l.textContent=c.text.substring(0,ci+1)+'|';ci++;setTimeout(typeNext,c.text[ci-1]===' '?80:60)}
    else{l.textContent=c.text;ti++;ci=0;setTimeout(typeNext,500)}
  }

  /* ── HOME ── */
  function showHome(){
    const home=document.createElement('div');home.className='main-home';home.id='mainHome';
    home.innerHTML=`
      <div class="main-home-title">
        <h1>Media SDA Ambolokandrina</h1>
        <p>Fitaovam-pivavahana sy fianarana</p>
      </div>
      <div class="home-cards">
        <div class="home-card bible" onclick="location.href='baibolyMG_v2.html'">
          <div class="hc-icon">&#x1F4D6;</div>
          <div class="hc-title">Baiboly Masina</div>
          <div class="hc-sub">Testamenta Taloha sy Vaovao</div>
          <div class="hc-badge">66 boky</div>
        </div>
        <div class="home-card hymns" onclick="location.href='fihirana_advantista.html'">
          <div class="hc-icon">&#x1F3B5;</div>
          <div class="hc-title">Fihirana Advantista</div>
          <div class="hc-sub">Hira fiderana 001–800</div>
          <div class="hc-badge">798 hira</div>
        </div>
        <div class="home-card sabata" onclick="openSlides()">
          <div class="hc-icon">=</div>
          <div class="hc-title">Programa Sabata</div>
          <div class="hc-sub">Filaharan'ny fanompoam-pivavahana</div>
          <div class="hc-badge">16 fizarana</div>
        </div>
      </div>
      <div class="home-sig">Media SDA Ambolokandrina</div>
    `;
    root.appendChild(home);
    requestAnimationFrame(()=>home.classList.add('visible'));
    try{localStorage.setItem('splashReady','1')}catch(e){}
  }

  /* ── SLIDESHOW ── */
  window.openSlides=function(){
    currentSlide=0;isPlaying=false;
    if(slideShowEl){slideShowEl.remove();slideShowEl=null}
    slideShowEl=document.createElement('div');slideShowEl.className='slideshow';

    let slidesHTML='';
    slides.forEach((s,i)=>{
      let inner=`<div class="slide-content">`;
      if(s.timer){
        const m=Math.floor(s.timer/60),sec=s.timer%60;
        inner+=`<h1>${s.title}</h1><div class="sub">${s.sub}</div>
          <div class="timer" id="timer${i}">${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}</div>
          <div class="timer-bar-wrap"><div class="timer-bar" id="timerBar${i}"></div></div>`;
      } else {
        inner+=`<h1>${s.title}</h1><div class="sub">${s.sub}</div>`;
      }
      inner+=`</div><div class="number">${String(s.id).padStart(2,'0')} / 16</div>`;
      slidesHTML+=`<div class="slide${i===0?' active':''}" id="slide${i}" style="background-image:url('data:image/webp;base64,')">${inner}</div>`;
    });

    slideShowEl.innerHTML=`
      <button class="slide-close" onclick="closeSlides()" aria-label="Hidy">&#x2716;</button>
      ${slidesHTML}
      <div class="slide-controls">
        <div class="ctrl-row">
          <button class="ctrl-btn" onclick="prevSlide()" aria-label="Teo aloha">&#x25C0;</button>
          <button class="play-btn" id="playBtn" onclick="togglePlay()" aria-label="Lalao / Hijanona">&#x25B6;</button>
          <button class="ctrl-btn" onclick="nextSlide()" aria-label="Manaraka">&#x25B6;</button>
          <div class="ctrl-progress" onclick="seekSlide(event)"><div class="ctrl-progress-fill" id="progressFill"></div></div>
          <div class="ctrl-label" id="ctrlLabel">01 / 16</div>
          <button class="ctrl-btn exit" onclick="closeSlides()" aria-label="Hivoaka">&#x2716;</button>
        </div>
      </div>
    `;
    document.body.appendChild(slideShowEl);
    requestAnimationFrame(()=>slideShowEl.classList.add('open'));

    timerDisplay=document.getElementById('timer0');
    timerBar=document.getElementById('timerBar0');
    progressFill=document.getElementById('progressFill');
    labelEl=document.getElementById('ctrlLabel');
    playBtn=document.getElementById('playBtn');
    updateControls();
    resetHideTimer();

  };

  let hideTimeout=null;
  function resetHideTimer(){
    if(!slideShowEl)return;
    const ctrl=slideShowEl.querySelector('.slide-controls');
    const close=slideShowEl.querySelector('.slide-close');
    if(ctrl)ctrl.style.opacity='1';if(close)close.style.opacity='1';
    if(hideTimeout)clearTimeout(hideTimeout);
    hideTimeout=setTimeout(()=>{
      if(!slideShowEl||!slideShowEl.classList.contains('open'))return;
      if(ctrl)ctrl.style.opacity='0';if(close)close.style.opacity='0';
    },2000);
  }

  document.addEventListener('keydown',function(e){
    if(!slideShowEl||!slideShowEl.classList.contains('open'))return;
    if(e.key==='ArrowRight'){nextSlide();resetHideTimer()}
    if(e.key==='ArrowLeft'){prevSlide();resetHideTimer()}
  });

  document.addEventListener('mousemove',function(){
    if(!slideShowEl||!slideShowEl.classList.contains('open'))return;
    resetHideTimer();
  });

  window.closeSlides=function(){
    if(timerInterval){clearInterval(timerInterval);timerInterval=null}
    slideShowEl.classList.remove('open');
    setTimeout(()=>{if(slideShowEl){slideShowEl.remove();slideShowEl=null}},500);
  };

  window.nextSlide=function(){
    if(currentSlide<slides.length-1){goTo(currentSlide+1)}
  };
  window.prevSlide=function(){
    if(currentSlide>0){goTo(currentSlide-1)}
  };
  window.seekSlide=function(e){
    const rect=e.currentTarget.getBoundingClientRect();
    const x=e.clientX-rect.left;
    const p=x/rect.width;
    const idx=Math.round(p*(slides.length-1));
    goTo(Math.max(0,Math.min(slides.length-1,idx)));
  };

  window.goTo=function goTo(idx){
    if(timerInterval){clearInterval(timerInterval);timerInterval=null;isPlaying=false;if(playBtn)playBtn.innerHTML='&#x25B6;'}
    document.getElementById('slide'+currentSlide).classList.remove('active');
    currentSlide=idx;
    document.getElementById('slide'+currentSlide).classList.add('active');
    timerDisplay=document.getElementById('timer'+currentSlide);
    timerBar=document.getElementById('timerBar'+currentSlide);
    updateControls();
    const s=slides[currentSlide];
    if(s.timer){
      timerRemaining=s.timer;
      setTimeout(()=>togglePlay(),300);
    }
    try{localStorage.setItem('sabataSlide',currentSlide)}catch(e){}
  }

  window.togglePlay=function(){
    const s=slides[currentSlide];
    if(!s.timer){return}
    if(timerInterval){clearInterval(timerInterval);timerInterval=null;isPlaying=false;playBtn.innerHTML='&#x25B6;';return}
    isPlaying=true;playBtn.innerHTML='&#x23F8;';
    if(timerRemaining<=0)timerRemaining=s.timer;
    timerInterval=setInterval(()=>{
      timerRemaining--;
      if(timerRemaining<=0){clearInterval(timerInterval);timerInterval=null;isPlaying=false;playBtn.innerHTML='&#x25B6;';timerRemaining=0}
      updateTimer();
    },1000);
  };

  function updateTimer(){
    if(!timerDisplay)return;
    const m=Math.floor(timerRemaining/60),sec=timerRemaining%60;
    timerDisplay.textContent=String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
    timerDisplay.classList.remove('pop');
    void timerDisplay.offsetWidth;
    timerDisplay.classList.add('pop');
    if(timerBar){
      const s=slides[currentSlide];
      const p=s.timer?timerRemaining/s.timer*100:0;
      timerBar.style.width=p+'%';
    }
  }

  function updateControls(){
    if(progressFill)progressFill.style.width=((currentSlide+1)/slides.length*100)+'%';
    if(labelEl)labelEl.textContent=String(currentSlide+1).padStart(2,'0')+' / '+String(slides.length).padStart(2,'0');
    const s=slides[currentSlide];
    if(s.timer){
      timerRemaining=s.timer;
      if(timerDisplay){
        const m=Math.floor(s.timer/60),sec=s.timer%60;
        timerDisplay.textContent=String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
      }
      if(timerBar)timerBar.style.width='100%';
      if(playBtn)playBtn.style.display='flex';
    } else {
      if(playBtn)playBtn.style.display='none';
    }
  }

  setTimeout(typeNext,400);
})();
</script>
<style>
/* floating nav */
#floatNav{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:99999;display:flex;align-items:center;gap:4px;padding:6px 10px;border-radius:30px;background:rgba(10,15,30,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.12);box-shadow:0 4px 24px rgba(0,0,0,.5);transition:opacity .4s ease,transform .4s ease;opacity:1}
#floatNav.hide{opacity:0;transform:translateX(-50%) translateY(12px);pointer-events:none}
#floatNav a{display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;text-decoration:none;font-size:16px;transition:all .2s;color:rgba(255,255,255,.5);background:transparent}
#floatNav a:hover{background:rgba(255,255,255,.1);color:rgba(255,255,255,.9);transform:scale(1.1)}
#floatNav a.active{background:rgba(10,132,255,.25);color:#0A84FF}
#floatNav .sabata-link{background:rgba(52,199,89,.15);color:#34C759}
#floatNav .sabata-link:hover{background:rgba(52,199,89,.3);color:#34C759}
</style>
<div id="floatNav">
  <a href="index.html" class="active" title="Fandraisana">🏠</a>
  <a href="javascript:void(0)" class="sabata-link" id="sabataNavBtn" title="Programa Sabata">▶</a>
  <a href="baibolyMG_v2.html" title="Baiboly">📖</a>
  <a href="fihirana_advantista.html" title="Fihirana">🎵</a>
</div>
<script>
(function(){var n=document.getElementById('floatNav'),t=null;function s(){n.classList.remove('hide');if(t)clearTimeout(t);t=setTimeout(function(){n.classList.add('hide')},3000)}document.addEventListener('mousemove',s);document.addEventListener('touchstart',s);document.addEventListener('click',s);s()})();
document.getElementById('sabataNavBtn').addEventListener('click',function(){
  if(typeof openSlides==='function'){
    openSlides();
    try{
      var saved=parseInt(localStorage.getItem('sabataSlide'));
      if(!isNaN(saved)&&saved>0){
        setTimeout(function(){if(typeof window.goTo==='function')window.goTo(saved)},600);
      }
    }catch(e){}
  }
});
</script>
</body>
</html>
